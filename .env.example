# eostrata configuration — copy to .env and edit
# ─────────────────────────────────────────────────────────────────────────────


# ── Storage paths ─────────────────────────────────────────────────────────────

# Where converted Zarr data is stored (the main data store).
EOSTRATA_ZARR_ROOT=data/zarr

# Staging directory for raw downloaded files (temporary, can be cleared after ingestion).
EOSTRATA_RAW_DIR=data/raw

# Path to the dataset catalog index (JSON file listing all ingested datasets).
EOSTRATA_CATALOG_PATH=data/catalog.json


# ── Area of interest ──────────────────────────────────────────────────────────
# Bounding box used when downloading datasets that support spatial subsetting.
# Decimal degrees, EPSG:4326. Default covers the entire globe.

EOSTRATA_BBOX_WEST=-180.0
EOSTRATA_BBOX_SOUTH=-90.0
EOSTRATA_BBOX_EAST=180.0
EOSTRATA_BBOX_NORTH=90.0


# ── Ingestion ─────────────────────────────────────────────────────────────────

# Number of dataset downloads that may run in parallel.
EOSTRATA_INGEST_MAX_WORKERS=3

# Total number of ingest jobs (queued + actively running) accepted before the
# server starts returning 429 Too Many Requests.
EOSTRATA_INGEST_MAX_QUEUED=20


# ── Store quota & eviction ────────────────────────────────────────────────────

# Maximum total size of the Zarr store in MB. 0 = unlimited.
# When a new download would push the store over this limit, the least-recently-
# used timestamps are removed one by one (oldest first, across all datasets)
# until enough space is free.
EOSTRATA_STORE_QUOTA_MB=0

# How many MB to keep free inside the quota before each download starts.
# A buffer of ~10% of the quota avoids repeated one-at-a-time evictions by
# clearing a meaningful chunk of space upfront.
# Example: quota=10000, buffer=1000 → evict until store ≤ 9000 MB.
# Set to 0 to disable (evict only the minimum needed). Ignored if >= quota.
EOSTRATA_STORE_EVICTION_BUFFER_MB=0

# Whether tile and zonal-stats requests update the per-timestamp last-access
# time used to decide eviction order (LRU). Set to false if you want eviction
# to follow ingestion order instead of access order.
EOSTRATA_TRACK_ACCESS=true


# ── Memory tuning ─────────────────────────────────────────────────────────────

# Spatial chunk size written into new Zarr groups (pixels, applied to both x
# and y). Affects memory use during writes and reads of that group.
# Changing this only impacts newly ingested datasets; existing groups keep
# their original chunk layout.
#
#   RAM available  →  recommended value
#   ≤ 512 MB       →  128 or 256
#     1–2 GB       →  256 or 512  (default)
#     ≥ 4 GB       →  512 or 1024
EOSTRATA_ZARR_CHUNK_SIZE=512

# ── Temporal aggregation batching ─────────────────────────────────────────────
# A tile or zonal-stats request that spans many timesteps (e.g. a 10-year mean)
# must load all those arrays to compute the result. This setting limits how many
# are held in memory at once, trading RAM for extra I/O passes.
# The computed result is always identical regardless of this value.
#
#   0  = load all timesteps in a single pass (lowest latency, highest peak RAM).
#   N  = never hold more than N timesteps in RAM at once. If the request spans
#        more than N timesteps, it is split into sequential batches of N.
#        Example: N=6, request covers 10 months → 2 batches (6 + 4 months).
#
#   RAM available  →  recommended value
#   ≤ 512 MB       →  1   (one timestep at a time)
#     1–2 GB       →  12  (one year of monthly data per batch)
#     ≥ 4 GB       →  0   (single pass)
EOSTRATA_MAX_AGGREGATION_TIMESTEPS=0

# Maximum number of aggregations (tile renders + zonal stats) allowed to run
# concurrently. Each aggregation loads one or more full spatial slices into RAM;
# serialising them avoids out-of-memory crashes on constrained instances.
# 0 = unlimited.
#
#   ≤ 1 GB RAM  →  1  (serialise all aggregations)
#   ≥ 4 GB RAM  →  0  (unlimited)
EOSTRATA_MAX_CONCURRENT_AGGREGATIONS=1

# ── Aggregation result cache ───────────────────────────────────────────────────
# When a tile or zonal-stats request arrives, eostrata aggregates all matching
# timesteps into a single 2-D result before slicing out the requested area.
#
# EOSTRATA_AGG_CACHE_MAX_ENTRIES=0 (default, memory-safe):
#   Each tile request clips its area first, then aggregates only that small
#   region. Peak RAM per request stays small, but adjacent tiles sharing the
#   same time range each pay the full aggregation cost independently.
#
# EOSTRATA_AGG_CACHE_MAX_ENTRIES=N (N > 0, faster map browsing):
#   The first request for a given (dataset, time range, operation) aggregates
#   the full spatial extent and holds the result in RAM. Subsequent tile
#   requests for the same aggregation read from the cache, avoiding redundant
#   computation — ideal when a user is panning or zooming a map. Each cached
#   entry holds one full-resolution 2-D array:
#     global CHIRPS (0.05°, 7200×3600 px): ~104 MB per entry
#     country-level 1-km dataset:           ~1–16 MB per entry
#
# Enable only when you have RAM headroom above normal operating use:
#   global datasets (CHIRPS, ERA5):  ≥ 2 GB RAM   →  4
#   country-level 1-km datasets:     ≥ 512 MB RAM  →  4
#   memory-constrained instances:    0  (leave disabled)
EOSTRATA_AGG_CACHE_MAX_ENTRIES=0

# How long (seconds) a cached aggregation result is kept before being
# recomputed on the next request. Only applies when AGG_CACHE_MAX_ENTRIES > 0.
EOSTRATA_AGG_CACHE_TTL_SECONDS=300


# ── Server ────────────────────────────────────────────────────────────────────

# Allowed CORS origins. Use ["*"] to allow any origin (suitable for public
# servers). For internal deployments, restrict to specific frontend URLs to
# block cross-site requests from untrusted origins.
# Example: EOSTRATA_CORS_ORIGINS=["https://app.example.com"]
EOSTRATA_CORS_ORIGINS=["*"]


# ── Logging ───────────────────────────────────────────────────────────────────

# Log file path. Rotates daily; 30 days of history are kept automatically.
# Set to empty string to disable file logging (stdout only).
EOSTRATA_LOG_FILE=data/eostrata.log


# ── Source credentials ────────────────────────────────────────────────────────
# Leave a credential empty to fall back to its file-based default (e.g.
# ~/.cdsapirc) or to use unauthenticated public access, as noted below.

# Sentinel NDVI — Copernicus Land Service (CGLS)
# Leave empty for unauthenticated public access (rate-limited).
# Register at https://land.copernicus.eu/global/ to obtain a token.
EOSTRATA_CGLS_API_KEY=

# ERA5 — Copernicus Climate Data Store (CDS)
# Leave empty to use ~/.cdsapirc if present.
# Register and obtain your key at https://cds.climate.copernicus.eu/how-to-api
EOSTRATA_CDS_URL=https://cds.climate.copernicus.eu/api
EOSTRATA_CDS_KEY=

# CAMS air quality — Copernicus Atmosphere Data Store (ADS)
# Leave empty to use ~/.adsapirc if present.
# Register and obtain your key at https://ads.atmosphere.copernicus.eu/how-to-api
EOSTRATA_ADS_URL=https://ads.atmosphere.copernicus.eu/api
EOSTRATA_ADS_KEY=

# TROPOMI — Copernicus Data Space Ecosystem (CDSE)
# Register for free at https://dataspace.copernicus.eu
EOSTRATA_CDSE_USER=
EOSTRATA_CDSE_PASSWORD=
