# eostrata configuration — copy to .env and edit

# Storage
EOSTRATA_ZARR_ROOT=data/zarr
EOSTRATA_RAW_DIR=data/raw
EOSTRATA_CATALOG_PATH=data/catalog.json

# Log file — rotates daily, 30 days of history kept.
# Set to empty string to disable file logging.
# EOSTRATA_LOG_FILE=data/eostrata.log

# Store quota — maximum size of the Zarr store in MB. 0 = unlimited.
# When a download would exceed this limit, the least-recently-used timestamps
# are evicted first (oldest first, one at a time across all groups).
# EOSTRATA_STORE_QUOTA_MB=0

# Eviction headroom — keep this many MB free inside the quota before each
# download. Recommended: ~10% of quota. Ignored if >= quota.
# Example: quota=10000, buffer=1000 → evict until store ≤ 9000 MB.
# EOSTRATA_STORE_EVICTION_BUFFER_MB=0

# Access tracking — when true (default), tile and zonal-stats requests update
# per-timestamp sentinel files used for LRU eviction ordering.
# Set to false if last_access should reflect ingestion time only.
# EOSTRATA_TRACK_ACCESS=true

# ── Memory tuning ────────────────────────────────────────────────────────────

# Zarr spatial chunk tile size (applied to both x and y dimensions).
# Each in-memory tile is chunk_size² × 4 bytes (float32).
# Halving this value quarters the per-operation footprint at the cost of more I/O.
# NOTE: only affects newly written Zarr groups; existing groups keep their layout.
#
#   ≤ 512 MB RAM → 128 or 256
#     1–2 GB RAM → 256 or 512  (default)
#       ≥ 4 GB   → 512 or 1024
# EOSTRATA_ZARR_CHUNK_SIZE=512

# Maximum timesteps loaded into memory for a single temporal aggregation.
# Requests exceeding this limit receive a 400 error. 0 = unlimited (default).
#
#   ≤ 512 MB RAM → 12  (one year of monthly data)
#     1–2 GB RAM → 60  (five years of monthly data)
#       ≥ 4 GB   → 0   (unlimited)
# EOSTRATA_MAX_AGGREGATION_TIMESTEPS=0

# Bounding box (west, south, east, north) — EPSG:4326
# Example: West Africa
EOSTRATA_BBOX_WEST=-18.0
EOSTRATA_BBOX_SOUTH=4.0
EOSTRATA_BBOX_EAST=15.0
EOSTRATA_BBOX_NORTH=24.0
